// Firestore 보안 규칙 예시
// Firebase Console > Firestore Database > Rules 탭에서 다음 규칙을 설정하세요

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== USER RULES ====================
    // 사용자는 자신의 데이터만 읽기/쓰기 가능
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      // 강아지 데이터 (서브컬렉션)
      match /dogs/{dogId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // ==================== DESIGNER RULES ====================
    // 모든 사용자가 디자이너 정보 읽기 가능
    match /designers/{designerId} {
      allow read: if true;
      allow write: if request.auth.uid == designerId;
    }

    // ==================== BOOKING RULES ====================
    // 예약은 해당 사용자와 디자이너만 접근 가능
    match /bookings/{bookingId} {
      allow read: if request.auth.uid == resource.data.userId || 
                     request.auth.uid == resource.data.designerId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // ==================== QUOTE RULES ====================
    // 견적 요청은 요청자와 디자이너만 접근 가능
    match /quotes/{quoteId} {
      allow read: if request.auth.uid == resource.data.userId || 
                     request.auth.uid == resource.data.designerId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth.uid == resource.data.designerId;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ==================== REVIEW RULES ====================
    // 후기는 모두 읽기 가능, 작성자만 쓰기 가능
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // ==================== MESSAGE RULES ====================
    // 채팅 메시지는 해당 채팅방 참여자만 접근 가능
    match /chatRooms/{chatRoomId} {
      allow read: if true;
      
      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.auth.uid == request.resource.data.userId;
        allow update, delete: if request.auth.uid == resource.data.userId;
      }
    }

    // ==================== NOTIFICATIONS RULES ====================
    // 알림은 해당 사용자만 접근 가능
    match /notifications/{notificationId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow create: if true; // 시스템이 생성
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ==================== FAVORITES RULES ====================
    // 즐겨찾기는 해당 사용자만 접근 가능
    match /favorites/{favoriteId} {
      allow read, write: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // ==================== DEFAULT DENY ====================
    // 명시되지 않은 모든 접근은 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
