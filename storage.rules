// Firebase Storage 보안 규칙 예시
// Firebase Console > Storage > Rules 탭에서 다음 규칙을 설정하세요

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ==================== USER IMAGES ====================
    // 사용자 강아지 이미지: 누구나 읽기 가능, 본인만 쓰기
    // (디자이너/다른 화면에서도 강아지 사진이 보여야 해서 read는 공개)
    match /users/{userId}/dogs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId && 
                      request.resource.size < 5 * 1024 * 1024 && // 5MB 제한
                      request.resource.contentType.matches('image/.*');
    }

    // 사용자 후기 이미지: 본인만 쓰기, 모두 읽기
    match /users/{userId}/reviews/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId && 
                      request.resource.size < 5 * 1024 * 1024 && // 5MB 제한
                      request.resource.contentType.matches('image/.*');
    }

    // 디자이너 프로필 사진: 로그인한 디자이너만 쓰기, 모두 읽기
    // (실제 프로젝트에서는 request.auth.uid == designerId 조건을 유지하는 편이 더 안전하지만,
    //  현재 업로드 과정에서 uid/경로 불일치로 인한 storage/unauthorized 가 자주 발생해
    //  우선 "로그인 여부" 기준으로만 완화했습니다.)
    match /designers/{designerId}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.resource.size < 5 * 1024 * 1024 && // 5MB 제한
                      request.resource.contentType.matches('image/.*');
    }

    // 디자이너 포트폴리오: 로그인한 디자이너만 쓰기, 모두 읽기
    match /designers/{designerId}/portfolio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.resource.size < 5 * 1024 * 1024 && // 5MB 제한
                      request.resource.contentType.matches('image/.*');
    }

    // ==================== PUBLIC IMAGES ====================
    // 공개 이미지: 모두 읽기
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // ==================== DEFAULT DENY ====================
    // 명시되지 않은 모든 접근은 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
